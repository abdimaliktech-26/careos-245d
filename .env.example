NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI (env-driven; platform runs fully with AI disabled/unconfigured)
AI_PROVIDER=anthropic            # anthropic | openai | none
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=                  # optional fallback provider
ANTHROPIC_MODEL=                 # optional override (default claude-haiku-4-5)
OPENAI_MODEL=                    # optional override (default gpt-4o-mini)
AI_MONTHLY_LIMIT_DEFAULT=2000    # default per-org monthly AI call cap

# App branding (per deployment)
NEXT_PUBLIC_APP_NAME=Higsi

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# Scheduled audit endpoint
CRON_SECRET=generate-a-long-random-secret
AUDIT_CRON_SECRET=generate-a-long-random-secret

# Optional email delivery
RESEND_API_KEY=
AUDIT_EMAIL_FROM="Higsi <audits@yourdomain.com>"

# Optional SMS delivery
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# EVV state aggregator (HHAeXchange / Sandata)
# The aggregator API key is referenced BY NAME from evv_aggregator_config.credential_ref.
# Store the actual secret here (or in the Vercel/secret store) using an UPPER_SNAKE_CASE name,
# then set that name as the org's credential_ref. The DB never holds the secret value.
HHAEXCHANGE_API_KEY=
SANDATA_API_KEY=
